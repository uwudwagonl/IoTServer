# MQTT broker connection (WebSocket). Used as the default; users can override
# per-browser via the broker switcher in the dashboard.
# Pi via Cloudflare quick tunnel (default — works from Vercel and localhost):
NEXT_PUBLIC_MQTT_BROKER_URL=wss://things-defense-christina-lands.trycloudflare.com
# Pi on the school LAN (faster for local dev, LAN-only):
# NEXT_PUBLIC_MQTT_BROKER_URL=ws://10.252.74.225:9001
# Ubuntu broker (legacy):
# NEXT_PUBLIC_MQTT_BROKER_URL=wss://blues-brian-employee-episodes.trycloudflare.com
